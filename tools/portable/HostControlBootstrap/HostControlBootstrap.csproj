<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <UseWindowsForms>true</UseWindowsForms>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <PublishSingleFile>true</PublishSingleFile>
    <SelfContained>true</SelfContained>
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
    <EnableCompressionInSingleFile>true</EnableCompressionInSingleFile>
    <PublishTrimmed>false</PublishTrimmed>
    <DebugType>none</DebugType>
    <DebugSymbols>false</DebugSymbols>
    <AssemblyName>cloudgime-host-bootstrap</AssemblyName>
    <RootNamespace>CloudgimeHostBootstrap</RootNamespace>
  </PropertyGroup>

  <ItemGroup>
    <Compile Remove="obj-publish-temp\**\*.cs" />
    <EmbeddedResource Remove="obj-publish-temp\**\*" />
    <None Remove="obj-publish-temp\**\*" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Nefarius.ViGEm.Client" Version="1.17.183" />
    <PackageReference Include="System.Management" Version="8.0.0" />
  </ItemGroup>
</Project>
